[bootstrap]
main_collection = /example/example.collectionc

[script]
shared_state = 1

[display]
width = 960
height = 640
high_dpi = 1

[android]
input_method = HiddenInputField
minimum_sdk_version = 21
package = com.halfstaratelier.webpexample

[physics]
gravity_y = -1000.0
scale = 0.01

[html5]
scale_mode = stretch

[project]
title = webp
custom_resources = assets

[library]
include_dirs = webp

